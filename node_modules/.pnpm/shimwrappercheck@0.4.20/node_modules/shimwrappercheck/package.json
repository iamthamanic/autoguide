{
  "name": "shimwrappercheck",
  "version": "0.4.20",
  "workspaces": [
    "packages/*"
  ],
  "description": "CLI-Shim, der Projekt-Checks ausführt, bevor ein echtes CLI-Kommando (z. B. Supabase, Git) läuft. Optional: Web-Dashboard zum Konfigurieren von Presets, Trigger-Befehlen, Checks und AGENTS.md.",
  "license": "MIT",
  "bin": {
    "supabase": "bin/supabase",
    "shimwrappercheck": "bin/shimwrappercheck",
    "git": "bin/git",
    "shim": "bin/shim"
  },
  "files": [
    "bin",
    "packages/core/dist",
    "packages/cli/dist",
    "scripts",
    "templates",
    "docs",
    "dashboard/app",
    "dashboard/components",
    "dashboard/i18n",
    "dashboard/lib",
    "dashboard/messages",
    "dashboard/scripts",
    "dashboard/package.json",
    "dashboard/next.config.js",
    "dashboard/postcss.config.js",
    "dashboard/tailwind.config.js",
    "dashboard/tsconfig.json",
    "dashboard/next-env.d.ts",
    "dashboard/README.md",
    "README.md",
    "AGENTS.md",
    "mcp/package.json",
    "mcp/server.js",
    "mcp/core-bridge.js",
    "mcp/tools",
    "mcp/README.md",
    "scripts/mcp-setup.js",
    "scripts/structured-cli.js",
    "scripts/lib/mcp-client-config.js",
    "scripts/lib/mcp-client-toml.js",
    "scripts/lib/project-api.js",
    "scripts/lib/project-config-api.js",
    "scripts/lib/project-runtime-api.js",
    "scripts/lib/structured-cli-helpers.js",
    "scripts/lib/core-bridge.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "node scripts/prepublish-clean.js",
    "build": "npm run build -w @shimwrappercheck/core && npm run build -w @shimwrappercheck/cli",
    "build:dashboard": "npm run build --prefix dashboard",
    "dev": "npm run dashboard",
    "dashboard": "npm install --prefix dashboard && npm run dev --prefix dashboard",
    "setup": "node bin/shimwrappercheck setup",
    "init": "node bin/shimwrappercheck init",
    "supabase:checked": "supabase",
    "git:checked": "./bin/git",
    "mcp": "node mcp/server.js",
    "mcp-setup": "node scripts/mcp-setup.js",
    "dashboard:check": "npm run check --prefix dashboard",
    "lint": "npm run lint --prefix dashboard",
    "format:check": "prettier --check \"packages/**/*.{ts,json}\" \"scripts/**/*.{js,sh}\" \"*.{json,md}\" && npm run format:check --prefix dashboard",
    "shellcheck": "command -v shellcheck >/dev/null && shellcheck scripts/*.sh bin/*.sh || echo 'shellcheck not installed, skip'",
    "typecheck": "npm run build -w @shimwrappercheck/core && npm run typecheck -w @shimwrappercheck/core && npm run typecheck -w @shimwrappercheck/cli && npm run typecheck --prefix dashboard",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run",
    "test:run": "npm run build --prefix dashboard",
    "test:mutation": "npm run build --prefix dashboard -- --no-lint",
    "checks": "npm run build && ./scripts/run-checks.sh",
    "check:mock-data": "true"
  },
  "dependencies": {
    "dotenv": "^17.2.4"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.5.1",
    "@types/node": "^22.13.10",
    "prettier": "^3.8.1",
    "shimwrappercheck": "^0.4.7",
    "snyk": "^1.1302.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.9",
    "zod": "^3.24.2"
  }
}
