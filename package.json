{
  "name": "autoguide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Documentation intelligence engine for process-heavy software",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @autoguide/example-react-vite dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "verify": "pnpm typecheck && pnpm test",
    "checks": "pnpm run verify",
    "test:e2e": "echo 'Add Playwright — see verify-ui skill'"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
