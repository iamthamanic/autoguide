{
  "name": "autoguide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Documentation intelligence engine for process-heavy software",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @iamthamanic/autoguide-example-react-vite dev",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r run typecheck",
    "test": "vitest run && pnpm -r run test",
    "verify": "pnpm -r run build && pnpm typecheck && pnpm test",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "checks": "pnpm run verify",
    "test:e2e": "echo 'Add Playwright — see verify-ui skill'"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
