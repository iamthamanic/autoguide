# Optional AI provider keys — copy to .env, never commit real values

# Local Ollama (default, no key required)
# AUTOGuide_AI_PROVIDER=ollama
# AUTOGuide_AI_ENDPOINT=http://localhost:11434

# Cloud (opt-in — user supplies key + URL)
# AUTOGuide_AI_PROVIDER=openai-compatible
# AUTOGuide_AI_API_KEY=
# AUTOGuide_AI_ENDPOINT=https://api.openai.com/v1
