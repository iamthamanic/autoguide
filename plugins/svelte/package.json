{
  "name": "@iamthamanic/autoguide-svelte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Svelte adapter for AutoGuide Help Widget and Inspector",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "svelte-package -i src -o dist --tsconfig tsconfig.json",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "test": "pnpm run build && vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@iamthamanic/autoguide-core": "workspace:*",
    "@iamthamanic/autoguide-runtime": "workspace:*",
    "@iamthamanic/autoguide-ui": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/svelte": "^5.2.8",
    "jsdom": "^26.1.0",
    "svelte": "^5.43.14",
    "svelte-check": "^4.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
