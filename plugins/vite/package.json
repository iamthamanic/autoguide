{
  "name": "@iamthamanic/autoguide-vite",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "description": "Vite plugin — virtual:autoguide module and public artifact copy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamthamanic/autoguide.git",
    "directory": "plugins/vite"
  },
  "keywords": [
    "autoguide",
    "vite",
    "plugin",
    "documentation",
    "sdk"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
