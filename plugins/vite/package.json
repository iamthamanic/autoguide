{
  "name": "@autoguide/vite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vite plugin — virtual:autoguide module and public artifact copy",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
