{
  "name": "@autoguide/tauri",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tauri 2 bridge for AutoGuide webview runtime and app-data storage paths",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@autoguide/config": "workspace:*",
    "@autoguide/core": "workspace:*",
    "@autoguide/runtime": "workspace:*"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.9.1",
    "vitest": "^3.2.4"
  }
}
