{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoguide.dev/schemas/features.schema.json",
  "title": "AutoGuide features.json",
  "version": "0.1.0",
  "type": "array",
  "items": { "$ref": "#/$defs/feature" },
  "$defs": {
    "feature": {
      "type": "object",
      "required": [
        "id",
        "title",
        "pageIds",
        "roleIds",
        "elementIds",
        "flowIds",
        "factIds",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "pageIds": { "type": "array", "items": { "type": "string" } },
        "roleIds": { "type": "array", "items": { "type": "string" } },
        "elementIds": { "type": "array", "items": { "type": "string" } },
        "flowIds": { "type": "array", "items": { "type": "string" } },
        "factIds": { "type": "array", "items": { "type": "string" } },
        "status": {
          "$ref": "https://autoguide.dev/schemas/shared.schema.json#/$defs/recordStatus"
        }
      }
    }
  }
}
