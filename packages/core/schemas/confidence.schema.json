{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoguide.dev/schemas/confidence.schema.json",
  "title": "AutoGuide confidence.json",
  "version": "0.1.0",
  "type": "object",
  "required": ["scores"],
  "additionalProperties": false,
  "properties": {
    "scores": {
      "type": "object",
      "additionalProperties": {
