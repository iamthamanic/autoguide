{
  "name": "@iamthamanic/autoguide-cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "AutoGuide CLI — init, scan, review, export, sync, publish",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamthamanic/autoguide.git",
    "directory": "packages/cli"
  },
  "keywords": ["autoguide", "cli", "documentation", "scanner", "sdk"],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "autoguide": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@iamthamanic/autoguide-ai": "workspace:*",
    "@iamthamanic/autoguide-config": "workspace:*",
    "@iamthamanic/autoguide-core": "workspace:*",
    "@iamthamanic/autoguide-export": "workspace:*",
    "@iamthamanic/autoguide-playwright": "workspace:*",
    "@iamthamanic/autoguide-scanner": "workspace:*",
    "@iamthamanic/autoguide-storage": "workspace:*",
    "ajv": "^8.17.1",
    "commander": "^13.1.0"
  }
}