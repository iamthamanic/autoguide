{
  "name": "@autoguide/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AutoGuide CLI — init, scan, review, export",
  "bin": {
    "autoguide": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@autoguide/ai": "workspace:*",
    "@autoguide/config": "workspace:*",
    "@autoguide/core": "workspace:*",
    "@autoguide/export": "workspace:*",
    "@autoguide/playwright": "workspace:*",
    "@autoguide/scanner": "workspace:*",
    "@autoguide/storage": "workspace:*",
    "ajv": "^8.17.1",
    "commander": "^13.1.0"
  }
}
