{
  "name": "@iamthamanic/autoguide-storage",
  "version": "0.1.1",
  "private": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "JSON persistence and SQLite index for AutoGuide",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
