{
  "name": "@autoguide/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Framework-agnostic design tokens and headless widget primitives",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/tokens.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@autoguide/core": "workspace:*"
  }
}
