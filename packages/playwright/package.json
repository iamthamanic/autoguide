{
  "name": "@iamthamanic/autoguide-playwright",
  "version": "0.1.8",
  "private": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Playwright trace import, crawl fallback, and flow generation for AutoGuide",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@iamthamanic/autoguide-core": "workspace:*",
    "@iamthamanic/autoguide-runtime": "workspace:*"
  },
  "optionalDependencies": {
    "playwright": "^1.51.0"
  }
}
