{
  "name": "@autoguide/playwright",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright trace import, crawl fallback, and flow generation for AutoGuide",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@autoguide/core": "workspace:*",
    "@autoguide/runtime": "workspace:*"
  },
  "optionalDependencies": {
    "playwright": "^1.51.0"
  }
}
