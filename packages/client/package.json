{
  "name": "@iamthamanic/autoguide-client",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "description": "Browser-safe loader for AutoGuide knowledge artifacts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamthamanic/autoguide.git",
    "directory": "packages/client"
  },
  "keywords": [
    "autoguide",
    "documentation",
    "browser",
    "loader",
    "sdk"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@iamthamanic/autoguide-core": "workspace:*"
  }
}
